{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-radical-libertarian.vercel.app/schemas/resource.schema.json",
  "title": "Resource",
  "type": "object",
  "required": ["title", "category", "status"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 2 },
    "category": { "type": "string" },
    "url": { "type": "string" },
    "localPage": { "type": "string" },
    "description": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["planned", "scaffolded", "active", "external-resource", "needs-review", "archived"] },
    "notes": { "type": "string" }
  }
}
