{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-radical-libertarian.vercel.app/schemas/manifesto.schema.json",
  "title": "Manifesto Point",
  "type": "object",
  "required": ["title", "order", "body", "status"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string" },
    "order": { "type": "integer", "minimum": 1 },
    "body": { "type": "string" },
    "shortVersion": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["draft", "approved", "published", "archived"] }
  }
}
